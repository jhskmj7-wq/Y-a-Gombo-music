rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default-deny all requests
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY & IDENTITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role lookups using get() on user profile
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserRole() == 'admin';
    }

    // --- STRUCTURAL VALIDATORS (ANTI-UPDATE-GAP SPECS) ---
    
    // Strict schema & identity checks for user profiles
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['client', 'musicien', 'admin'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('id' in data) || (data.id is string && data.id.size() <= 128)) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 200)) &&
             (!('firstName' in data) || (data.firstName is string && data.firstName.size() <= 100)) &&
             (!('lastName' in data) || (data.lastName is string && data.lastName.size() <= 100)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 250)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2083)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 2083)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 51)) &&
             (!('commune' in data) || (data.commune is string && data.commune.size() <= 100)) &&
             (!('provider' in data) || (data.provider is string && data.provider.size() <= 100)) &&
             (!('isProfileComplete' in data) || (data.isProfileComplete is bool)) &&
             (!('balance' in data) || (data.balance is int)) &&
             (!('totalRevenue' in data) || (data.totalRevenue is int)) &&
             (!('totalWithdrawals' in data) || (data.totalWithdrawals is int)) &&
             (!('gigsCompleted' in data) || (data.gigsCompleted is int)) &&
             (!('applicationsSent' in data) || (data.applicationsSent is int)) &&
             (!('acceptanceRate' in data) || (data.acceptanceRate is int)) &&
             (!('orangeMoneyNumber' in data) || (data.orangeMoneyNumber is string && data.orangeMoneyNumber.size() <= 51)) &&
             (!('moovMoneyNumber' in data) || (data.moovMoneyNumber is string && data.moovMoneyNumber.size() <= 51)) &&
             (!('waveNumber' in data) || (data.waveNumber is string && data.waveNumber.size() <= 51)) &&
             (!('paymentMethods' in data) || (data.paymentMethods is list && data.paymentMethods.size() <= 10)) &&
             (!('experience' in data) || (data.experience is string && data.experience.size() <= 100)) &&
             (!('specialty' in data) || (data.specialty is string && data.specialty.size() <= 100)) &&
             (!('speciality' in data) || (data.speciality is string && data.speciality.size() <= 100)) &&
             (!('experienceYears' in data) || (data.experienceYears is string && data.experienceYears.size() <= 100)) &&
             (!('musicGenre' in data) || (data.musicGenre is string && data.musicGenre.size() <= 100)) &&
             (!('artistName' in data) || (data.artistName is string && data.artistName.size() <= 100)) &&
             (!('paymentNumber' in data) || (data.paymentNumber is string && data.paymentNumber.size() <= 50)) &&
             (!('paymentProvider' in data) || (data.paymentProvider is string && data.paymentProvider.size() <= 50)) &&
             (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50)) &&
             (!('isVerified' in data) || (data.isVerified is bool));
    }

    // Validate a Show Gombo Prestation
    function isValidGombo(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.status in ['open', 'closed', 'publie', 'reserve', 'termine'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (data.createdBy == request.auth.uid || data.clientId == request.auth.uid) &&
             (!('clientName' in data) || (data.clientName is string && data.clientName.size() <= 200)) &&
             (!('type' in data) || (data.type is string && data.type.size() <= 100)) &&
             (!('eventType' in data) || (data.eventType is string && data.eventType.size() <= 50)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 300)) &&
             (!('commune' in data) || (data.commune is string && data.commune.size() <= 100)) &&
             (!('date' in data) || (data.date is string && data.date.size() <= 20)) &&
             (!('time' in data) || (data.time is string && data.time.size() <= 20)) &&
             (!('budget' in data) || (data.budget is int && data.budget >= 0)) &&
             (!('mediaURL' in data) || (data.mediaURL is string && data.mediaURL.size() <= 2083)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2083)) &&
             (!('applicationsCount' in data) || (data.applicationsCount is int && data.applicationsCount >= 0)) &&
             (!('musiciansCount' in data) || (data.musiciansCount is int && data.musiciansCount >= 0)) &&
             (!('urgent' in data) || (data.urgent is bool));
    }

    // Validate an application Candidacy
    function isValidApplication(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.gomboId is string && data.gomboId.size() <= 128 &&
             (data.userId == request.auth.uid || data.musicianId == request.auth.uid) &&
             data.message is string && data.message.size() <= 2000 &&
             data.status in ['pending', 'accepted', 'rejected', 'en_attente', 'accepte', 'rejete', 'refuse'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('gomboTitle' in data) || (data.gomboTitle is string && data.gomboTitle.size() <= 200)) &&
             (!('musicianName' in data) || (data.musicianName is string && data.musicianName.size() <= 200)) &&
             (!('musicianSpecialty' in data) || (data.musicianSpecialty is string && data.musicianSpecialty.size() <= 100)) &&
             (!('musicianPhone' in data) || (data.musicianPhone is string && data.musicianPhone.size() <= 51)) &&
             (!('musicianAvatar' in data) || (data.musicianAvatar is string && data.musicianAvatar.size() <= 2083)) &&
             (!('mediaURL' in data) || (data.mediaURL is string && data.mediaURL.size() <= 2083)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2083)) &&
             (!('applicantId' in data) || (data.applicantId is string && data.applicantId.size() <= 128)) &&
             (!('applicantName' in data) || (data.applicantName is string && data.applicantName.size() <= 200)) &&
             (!('applicantPhoto' in data) || (data.applicantPhoto is string && data.applicantPhoto.size() <= 2083)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 51)) &&
             (!('specialty' in data) || (data.specialty is string && data.specialty.size() <= 100)) &&
             (!('disponibilite' in data) || (data.disponibilite is string && data.disponibilite.size() <= 150)) &&
             (!('availability' in data) || (data.availability is string && data.availability.size() <= 150)) &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 2083)) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 2083));
    }

    // Validate a notification document
    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.type is string && data.type.size() <= 100 &&
             data.message is string && data.message.size() <= 1000 &&
             (!('title' in data) || (data.title is string && data.title.size() <= 200)) &&
             (data.read is bool || data.isRead is bool) &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    // Validate waiting feature analytics collections
    function isValidWaitingFeature(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.featureName is string && data.featureName.size() <= 100 &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (data.uid == request.auth.uid || data.userId == request.auth.uid) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 200)) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('status' in data) || (data.status == 'locked')) &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000));
    }

    // Validate secure administrator trace logs
    function isValidAdminLog(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.action is string && data.action.size() <= 100 &&
             data.targetId is string && data.targetId.size() <= 128 &&
             data.performedBy == request.auth.uid &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    // Validate reservations
    function isValidReservation(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.gomboId is string && data.gomboId.size() <= 128 &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.musicianId is string && data.musicianId.size() <= 128 &&
             data.amount is int && data.amount >= 0 &&
             data.status in ['confirme', 'complete', 'annule'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('gomboTitle' in data) || (data.gomboTitle is string && data.gomboTitle.size() <= 200)) &&
             (!('musicianName' in data) || (data.musicianName is string && data.musicianName.size() <= 200)) &&
             (!('musicianPhone' in data) || (data.musicianPhone is string && data.musicianPhone.size() <= 51));
    }

    // Validate a Social Post
    function isValidSocialPost(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 200 &&
             data.title is string && data.title.size() <= 300 &&
             data.caption is string && data.caption.size() <= 3000 &&
             (!('userAvatar' in data) || (data.userAvatar is string && data.userAvatar.size() <= 2083)) &&
             (!('userRole' in data) || (data.userRole is string && data.userRole.size() <= 200)) &&
             (!('beatProd' in data) || (data.beatProd is string && data.beatProd.size() <= 200)) &&
             (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 2083)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2083)) &&
             (!('likesCount' in data) || (data.likesCount is int && data.likesCount >= 0)) &&
             (!('sharesCount' in data) || (data.sharesCount is int && data.sharesCount >= 0)) &&
             (!('savesCount' in data) || (data.savesCount is int && data.savesCount >= 0)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 50)) &&
             (!('likedBy' in data) || (data.likedBy is list && data.likedBy.size() <= 10000)) &&
             (!('savedBy' in data) || (data.savedBy is list && data.savedBy.size() <= 10000)) &&
             (!('comments' in data) || (data.comments is list && data.comments.size() <= 1000)) &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }


    // Validate Renfort Express postings
    function isValidRenfort(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 300 &&
             data.description is string && data.description.size() <= 3000 &&
             data.status in ['publie', 'termine'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('instrument' in data) || (data.instrument is string && data.instrument.size() <= 100)) &&
             (!('instruments' in data) || (data.instruments is list && data.instruments.size() <= 30)) &&
             (!('date' in data) || (data.date is string && data.date.size() <= 20)) &&
             (!('time' in data) || (data.time is string && data.time.size() <= 20)) &&
             (!('musiciansCount' in data) || (data.musiciansCount is int && data.musiciansCount >= 0)) &&
             (!('budget' in data) || (data.budget is int && data.budget >= 0)) &&
             (!('commune' in data) || (data.commune is string && data.commune.size() <= 150)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 51)) &&
             (!('requestType' in data) || (data.requestType is string && data.requestType.size() <= 100)) &&
             (!('genres' in data) || (data.genres is list && data.genres.size() <= 30));
    }

    // Validate Renfort Express applications
    function isValidRenfortApplication(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.renfortId is string && data.renfortId.size() <= 128 &&
             data.musicianId == request.auth.uid &&
             data.status in ['en_attente', 'accepte', 'refuse'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('renfortTitle' in data) || (data.renfortTitle is string && data.renfortTitle.size() <= 200)) &&
             (!('musicianName' in data) || (data.musicianName is string && data.musicianName.size() <= 200)) &&
             (!('musicianPhone' in data) || (data.musicianPhone is string && data.musicianPhone.size() <= 51)) &&
             (!('musicianAvatar' in data) || (data.musicianAvatar is string && data.musicianAvatar.size() <= 2083)) &&
             (!('musicianSpecialties' in data) || (data.musicianSpecialties is list && data.musicianSpecialties.size() <= 30));
    }


    // Validate a Certification Request
    function isValidCertificationRequest(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.artistName is string && data.artistName.size() <= 200 &&
             data.experience is string && data.experience.size() <= 200 &&
             data.mediaUrl is string && data.mediaUrl.size() <= 2083 &&
             data.status in ['En attente', 'Approuvé', 'Refusé'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('specialties' in data) || (data.specialties is list && data.specialties.size() <= 30));
    }

    // Validate Côte d'Ivoire Music Group profiles
    function isValidMusicGroup(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.creatorId is string && data.creatorId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 2083)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 2083)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 3000)) &&
             (!('commune' in data) || (data.commune is string && data.commune.size() <= 150)) &&
             (!('ville' in data) || (data.ville is string && data.ville.size() <= 150)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 51)) &&
             (!('whatsapp' in data) || (data.whatsapp is string && data.whatsapp.size() <= 51)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('type' in data) || (data.type is string && data.type.size() <= 100)) &&
             (!('membersCount' in data) || (data.membersCount is int)) &&
             (!('creationYear' in data) || (data.creationYear is int)) &&
             (!('viewsCount' in data) || (data.viewsCount is int)) &&
             (!('favoritesCount' in data) || (data.favoritesCount is int)) &&
             (!('contactsCount' in data) || (data.contactsCount is int)) &&
             (!('isVerified' in data) || (data.isVerified is bool)) &&
             (!('isPremium' in data) || (data.isPremium is bool)) &&
             (!('isPopular' in data) || (data.isPopular is bool)) &&
             (!('plan' in data) || (data.plan in ['standard', 'vip', 'premium'])) &&
             (!('genres' in data) || (data.genres is list && data.genres.size() <= 30)) &&
             (!('followers' in data) || (data.followers is list && data.followers.size() <= 10000)) &&
             (!('members' in data) || (data.members is list && data.members.size() <= 200)) &&
             (!('gallery' in data) || (data.gallery is list && data.gallery.size() <= 200));
    }

    // Validate static/real-time Activity Feed events
    function isValidActivity(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.type in ['talent', 'groupe', 'certification', 'gombo'] &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             (!('userName' in data) || (data.userName is string && data.userName.size() <= 200)) &&
             (!('userAvatar' in data) || (data.userAvatar is string && data.userAvatar.size() <= 2083)) &&
             (!('targetId' in data) || (data.targetId is string && data.targetId.size() <= 128));
    }

    // Validate Verification Request
    function isValidVerificationRequest(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.photoUrl is string && data.photoUrl.size() <= 2083 &&
             data.commune is string && data.commune.size() <= 150 &&
             data.metier is string && data.metier.size() <= 150 &&
             data.whatsapp is string && data.whatsapp.size() <= 50 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             (!('selfieUrl' in data) || (data.selfieUrl is string && data.selfieUrl.size() <= 2083)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2083)) &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 200));
    }

    // Validate Chat Conversation
    function isValidConversation(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             data.updatedAt is string && data.updatedAt.size() <= 50;
    }

    // Validate Message
    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.conversationId is string && data.conversationId.size() <= 128 &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.type in ['text', 'image', 'audio'] &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2083)) &&
             (!('senderName' in data) || (data.senderName is string && data.senderName.size() <= 200)) &&
             data.timestamp is string && data.timestamp.size() <= 50;
    }


    // --- 1. USERS COLLECTION RULES ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(userId) && 
        isValidUser(request.resource.data) &&
        request.resource.data.role != 'admin'; // Prevent self-promoting to admin at signup
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
        isValidUser(request.resource.data) &&
        // Block standard users from promoting themselves to system roles
        (isOwner(userId) ? (request.resource.data.role == resource.data.role) : true);
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // --- 2. GOMBOS COLLECTION RULES ---
    match /gombos/{gomboId} {
      allow read: if true;
      allow create: if isSignedIn() && 
        isValidGombo(request.resource.data) &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)); // Global Consistency: check creator user profile exists
      allow update: if isSignedIn() && (
        ( (resource.data.createdBy == request.auth.uid || resource.data.clientId == request.auth.uid) && 
          resource.data.status != 'termine' && 
          resource.data.status != 'closed' &&
          isValidGombo(request.resource.data) ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && (resource.data.createdBy == request.auth.uid || resource.data.clientId == request.auth.uid));
    }

    // --- 3. APPLICATIONS COLLECTION RULES ---
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.musicianId == request.auth.uid ||
        get(/databases/$(database)/documents/gombos/$(resource.data.gomboId)).data.createdBy == request.auth.uid ||
        get(/databases/$(database)/documents/gombos/$(resource.data.gomboId)).data.clientId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && 
        isValidApplication(request.resource.data) &&
        exists(/databases/$(database)/documents/gombos/$(request.resource.data.gomboId)); // Global Consistency: Check linked gombo exists
      allow update: if isSignedIn() && (
        ( (resource.data.userId == request.auth.uid || resource.data.musicianId == request.auth.uid) && isValidApplication(request.resource.data) ) ||
        ( (get(/databases/$(database)/documents/gombos/$(resource.data.gomboId)).data.createdBy == request.auth.uid || 
           get(/databases/$(database)/documents/gombos/$(resource.data.gomboId)).data.clientId == request.auth.uid) && 
          request.resource.data.status in ['accepted', 'rejected', 'en_attente', 'accepte', 'rejete', 'refuse'] ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.musicianId == request.auth.uid));
    }

    // --- 4. NOTIFICATIONS COLLECTION RULES ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) &&
        (request.resource.data.read is bool || request.resource.data.isRead is bool);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- 5. WAITING FEATURES COLLECTION RULES ---
    match /waiting_features/{waitingId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidWaitingFeature(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // --- 6. ADMIN LOGS COLLECTION RULES ---
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // --- 7. RESERVATIONS COLLECTION RULES ---
    match /reservations/{reservationId} {
      allow read: if isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.musicianId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && 
        isValidReservation(request.resource.data) &&
        ( get(/databases/$(database)/documents/gombos/$(request.resource.data.gomboId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/gombos/$(request.resource.data.gomboId)).data.createdBy == request.auth.uid ||
          isAdmin() );
      allow update: if isSignedIn() && (
        ( (resource.data.clientId == request.auth.uid || resource.data.musicianId == request.auth.uid) && isValidReservation(request.resource.data) ) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- 8. POSTS COLLECTION RULES ---
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && 
        isValidSocialPost(request.resource.data) &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && (
        ( resource.data.userId == request.auth.uid && isValidSocialPost(request.resource.data) ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 9. RENFORTS COLLECTION RULES ---
    match /renforts/{renfortId} {
      allow read: if true;
      allow create: if isSignedIn() && 
        isValidRenfort(request.resource.data) &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && (
        ( resource.data.userId == request.auth.uid && isValidRenfort(request.resource.data) ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 10. RENFORT APPLICATIONS COLLECTION RULES ---
    match /renfortApplications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.musicianId == request.auth.uid ||
        get(/databases/$(database)/documents/renforts/$(resource.data.renfortId)).data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && 
        isValidRenfortApplication(request.resource.data) &&
        exists(/databases/$(database)/documents/renforts/$(request.resource.data.renfortId));
      allow update: if isSignedIn() && (
        ( resource.data.musicianId == request.auth.uid && isValidRenfortApplication(request.resource.data) ) ||
        ( get(/databases/$(database)/documents/renforts/$(resource.data.renfortId)).data.userId == request.auth.uid && request.resource.data.status in ['en_attente', 'accepte', 'refuse'] ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.musicianId == request.auth.uid);
    }

    // --- 11. MONETIZATION PREPARATION COLLECTIONS RULES ---
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /boosts/{boostId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /certifications/{certificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /certificationRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidCertificationRequest(request.resource.data);
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status && isValidCertificationRequest(request.resource.data)));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 12. MUSIC GROUPS COLLECTION RULES ---
    match /music_groups/{groupId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        isValidMusicGroup(request.resource.data) &&
        request.resource.data.creatorId == request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && (
        ( resource.data.creatorId == request.auth.uid && isValidMusicGroup(request.resource.data) ) ||
        // Allow anyone to update stats or follow: increment viewsCount, increment favoritesCount, augment followers, etc.
        ( isValidMusicGroup(request.resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['viewsCount', 'favoritesCount', 'contactsCount', 'followers']) ) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);
    }

    // --- 13. ACTIVITY FEED COLLECTION RULES ---
    match /activityFeed/{activityId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidActivity(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // --- 14. VERIFICATION REQUESTS COLLECTION RULES ---
    match /verificationRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidVerificationRequest(request.resource.data);
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status && isValidVerificationRequest(request.resource.data)));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- 15. CONVERSATIONS COLLECTION RULES ---
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && isValidConversation(request.resource.data);
      allow update: if isSignedIn() && ((request.auth.uid in resource.data.participants && isValidConversation(request.resource.data)) || isAdmin());
      allow delete: if isAdmin();
    }

    // --- 16. MESSAGES COLLECTION RULES ---
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        exists(/databases/$(database)/documents/conversations/$(resource.data.conversationId)) && 
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.participants ||
        isAdmin()
      );
      allow create: if isSignedIn() && isValidMessage(request.resource.data);
      allow update: if isSignedIn() && ((resource.data.senderId == request.auth.uid && isValidMessage(request.resource.data)) || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
    }

  }
}
